generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Kupac {
  id          Int        @id @default(autoincrement())
  tip         String
  naziv       String
  adresa      String
  mjesto      String
  email       String     @unique
  telefon     String
  pib         String?    @unique
  mbKompanije String?    @unique
  direktor    String?
  ime         String?
  prezime     String?
  jmbg        String?    @unique
  licniId     String?    @unique
  projekti    Projekat[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("kupci")
}

model Projekat {
  id        Int        @id @default(autoincrement())
  kupac     Kupac      @relation(fields: [kupacId], references: [id], onDelete: Cascade)
  kupacId   Int
  naziv     String
  snaga     Float
  lokacija  String
  status    String     @default("draft")
  faze      Faza[]
  dokumenti Dokument[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("projekti")
}

model Faza {
  id          Int        @id @default(autoincrement())
  projekat    Projekat   @relation(fields: [projektaId], references: [id], onDelete: Cascade)
  projektaId  Int
  fazaBroj    Int
  naziv       String
  opis        String?
  status      String     @default("pending")
  completed   Boolean    @default(false)
  completedAt DateTime?
  dokumenti   Dokument[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("faze")
}

model Dokument {
  id           Int       @id @default(autoincrement())
  projekat     Projekat  @relation(fields: [projektaId], references: [id], onDelete: Cascade)
  projektaId   Int
  faza         Faza      @relation(fields: [fazaId], references: [id], onDelete: Cascade)
  fazaId       Int
  broj         String
  naziv        String
  tipDokumenta String
  fileName     String?
  filePath     String?
  fileSize     Int?
  fileType     String?
  uploadedAt   DateTime?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("dokumenti")
}
